generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "control_plane"]
}

// ---------------------------------------------------------------------------
// control_plane – SaaS: tenants, subs, chaves, auditoria global, impersonação
// ---------------------------------------------------------------------------

enum ControlTenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  ARCHIVED

  @@schema("control_plane")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED

  @@schema("control_plane")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE

  @@schema("control_plane")
}

enum SubscriptionKeyStatus {
  ACTIVE
  ROTATED
  REVOKED

  @@schema("control_plane")
}

enum AuditActorType {
  SUPERADMIN_USER
  SYSTEM
  TENANT_USER

  @@schema("control_plane")
}

/// Operadores da plataforma (Control Plane) – autenticação separada dos utilizadores tenant.
model PlatformUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("platform_users")
  @@schema("control_plane")
}

/// Sessões de refresh token (rotação; hash opaco na BD, valor em cookie HttpOnly).
model AuthRefreshSession {
  id            String    @id @default(uuid()) @db.Uuid
  tokenHash     String    @unique @map("token_hash")
  subjectKind   String    @map("subject_kind")
  subjectId     String    @map("subject_id") @db.Uuid
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([subjectKind, subjectId])
  @@index([expiresAt])
  @@map("auth_refresh_sessions")
  @@schema("control_plane")
}

/// Token opaco para recuperação de palavra-passe (hash SHA-256 na BD).
model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  subjectKind String    @map("subject_kind")
  subjectId   String    @map("subject_id") @db.Uuid
  tenantSlug  String?   @map("tenant_slug")
  email       String
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_tokens")
  @@schema("control_plane")
}

model Tenant {
  id          String              @id @default(uuid()) @db.Uuid
  slug        String              @unique
  legalName   String              @map("legal_name")
  nif         String              @unique
  status      ControlTenantStatus @default(TRIAL)
  metadata    Json? // contactos, morada DGERT, etc.
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  // control_plane
  subscriptions         TenantSubscription[]
  subscriptionKeys      TenantSubscriptionKey[]
  impersonationSessions ImpersonationSession[]

  // public (dados operacionais isolados por tenant_id + RLS em produção)
  users           User[]
  tenantInvites   TenantInvite[]
  entidadesCliente EntidadeCliente[]
  propostasComerciais PropostaComercial[]
  leadsComerciais     LeadComercial[]
  configFaturacao     ConfigFaturacaoTenant?
  configProposta      ConfigPropostaTenant?
  seriesFaturacao     SerieFaturacao[]
  faturasComerciais   FaturaComercial[]
  notificacoesPortal  NotificacaoPortal[]
  formandos       FormandoProfile[]
  formadores      FormadorProfile[]
  cursos          Curso[]
  acoesFormacao   AcaoFormacao[]
  turmas          Turma[]
  matriculas      Matricula[]
  cronogramas     Cronograma[]
  sessoesFormacao SessaoFormacao[]
  sumarios        Sumario[]
  folhasPresenca  FolhaPresenca[]
  presencas       Presenca[]
  acessosLms      AcessoLms[]
  modulosConteudo ModuloConteudo[]
  modulosUnidade  ModuloUnidade[]
  progressosModulo ProgressoModulo[]
  arquivosExportacao ArquivoExportacao[]
  certificadosVerificacao CertificadoVerificacao[]
  tenantIntegracoes TenantIntegracao[]
  sigoSubmissoes SigoSubmissao[]
  rgpdPedidos RgpdPedido[]
  rgpdConsents RgpdConsent[]
  documentosAnexo DocumentoAnexo[]
  quizPerguntas QuizPergunta[]
  quizTentativas QuizTentativa[]
  avaliacoesFormando AvaliacaoFormando[]

  @@map("tenants")
  @@schema("control_plane")
}

model SubscriptionPlan {
  id                   String @id @default(uuid()) @db.Uuid
  code                 String @unique // starter | pro | enterprise
  name                 String
  priceCentsMonthly    Int        @map("price_cents_monthly")
  maxActiveUsers       Int?       @map("max_active_users") // null = ilimitado
  features             Json?
  active               Boolean    @default(true)
  createdAt            DateTime   @default(now()) @map("created_at")

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
  @@schema("control_plane")
}

model TenantSubscription {
  id                   String               @id @default(uuid()) @db.Uuid
  tenantId             String               @map("tenant_id") @db.Uuid
  planId               String               @map("plan_id") @db.Uuid
  status               SubscriptionStatus   @default(TRIALING)
  currentPeriodStart   DateTime             @map("current_period_start")
  currentPeriodEnd     DateTime             @map("current_period_end")
  cancelAtPeriodEnd    Boolean              @default(false) @map("cancel_at_period_end")
  billingEmail         String?              @map("billing_email")
  externalCustomerId   String?              @map("external_customer_id") // Stripe
  /** Add-ons activados em negociação comercial (códigos em @nexiforma/shared/billing). */
  customAddons         Json?                @default("[]") @map("custom_addons")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices  SubscriptionInvoice[]

  @@index([tenantId])
  @@index([status])
  @@map("tenant_subscriptions")
  @@schema("control_plane")
}

model SubscriptionInvoice {
  id                       String       @id @default(uuid()) @db.Uuid
  tenantSubscriptionId     String       @map("tenant_subscription_id") @db.Uuid
  periodStart              DateTime     @map("period_start") @db.Date
  periodEnd                DateTime     @map("period_end") @db.Date
  amountCents              Int          @map("amount_cents")
  currency                 String       @db.Char(3)
  status                   InvoiceStatus @default(DRAFT)
  paidAt                   DateTime?    @map("paid_at")
  externalInvoiceId        String?      @map("external_invoice_id")
  paymentMethodLast4       String?      @map("payment_method_last4")
  rawPayload               Json?        @map("raw_payload")
  createdAt                DateTime     @default(now()) @map("created_at")

  subscription TenantSubscription @relation(fields: [tenantSubscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantSubscriptionId])
  @@map("subscription_invoices")
  @@schema("control_plane")
}

model TenantSubscriptionKey {
  id                        String                   @id @default(uuid()) @db.Uuid
  tenantId                  String                   @map("tenant_id") @db.Uuid
  keyPrefix                 String                   @map("key_prefix") // ex. nf_live_
  keyHash                   String                   @map("key_hash") // argon2id ou bcrypt do segredo
  status                    SubscriptionKeyStatus     @default(ACTIVE)
  expiresAt                 DateTime?                @map("expires_at")
  maxActiveUsersSnapshot    Int?                     @map("max_active_users_snapshot")
  rotatedAt                 DateTime?               @map("rotated_at")
  revokedAt                 DateTime?               @map("revoked_at")
  createdAt                 DateTime                 @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Uma chave ACTIVE por tenant: enforcement na aplicação ou índice parcial SQL (migração manual)
  @@index([tenantId, status])
  @@map("tenant_subscription_keys")
  @@schema("control_plane")
}

model PlatformSalesLead {
  id              String   @id @default(uuid()) @db.Uuid
  nome            String
  email           String
  empresa         String?
  telefone        String?
  planoInteresse  String?  @map("plano_interesse")
  addonsInteresse Json?    @map("addons_interesse")
  mensagem        String?
  origem          String   @default("welcome")
  status          String   @default("NOVO")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([email])
  @@map("platform_sales_leads")
  @@schema("control_plane")
}

model GlobalAuditLog {
  id                       BigInt   @id @default(autoincrement())
  occurredAt               DateTime @default(now()) @map("occurred_at")
  actorType                AuditActorType @map("actor_type")
  actorId                  String             @map("actor_id") // Cognito sub / UUID plataforma
  actorIp                  String?            @map("actor_ip") @db.Inet
  action                   String
  resourceType             String             @map("resource_type")
  resourceId               String             @map("resource_id")
  targetTenantId           String?       @map("target_tenant_id") @db.Uuid
  targetUserId             String?       @map("target_user_id") @db.Uuid
  payload                  Json?
  prevHash                 Bytes?             @map("prev_hash") // opcional hash chain

  impersonationSessions ImpersonationSession[] @relation("ImpersonationAudit")

  @@index([occurredAt])
  @@index([targetTenantId])
  @@index([action])
  @@map("global_audit_logs")
  @@schema("control_plane")
}

model ImpersonationSession {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  targetUserId    String    @map("target_user_id") @db.Uuid
  superAdminId    String    @map("super_admin_id") // identificador plataforma (Cognito)
  reason          String
  jwtJti          String    @unique @map("jwt_jti")
  readOnly        Boolean   @default(true) @map("read_only")
  expiresAt       DateTime  @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  auditLogId      BigInt?   @map("audit_log_id")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetUser User            @relation("ImpersonatedUserSessions", fields: [targetUserId], references: [id], onDelete: Cascade)
  auditLog GlobalAuditLog?  @relation("ImpersonationAudit", fields: [auditLogId], references: [id])

  @@index([tenantId, createdAt])
  @@map("impersonation_sessions")
  @@schema("control_plane")
}

// ---------------------------------------------------------------------------
// public – dados operacionais (RLS futuro por tenant_id)
// ---------------------------------------------------------------------------

enum TenantUserRole {
  ADMIN
  COORDENADOR
  FORMADOR
  FORMANDO
  FINANCEIRO
  COMERCIAL

  @@schema("public")
}

enum AcaoEstado {
  PLANEADA
  EM_CURSO
  CONCLUIDA
  CANCELADA

  @@schema("public")
}

enum MatriculaEstado {
  ATIVA
  DESISTENCIA
  CONCLUSAO

  @@schema("public")
}

enum InscricoesEstado {
  ABERTAS
  FECHADAS

  @@schema("public")
}

enum SessaoEstado {
  AGENDADA
  REALIZADA
  CANCELADA

  @@schema("public")
}

enum ModuloConteudoTipo {
  VIDEO
  PDF
  SCORM
  TEXTO
  QUIZ
  WEBINAR

  @@schema("public")
}

model User {
  id           String           @id @default(uuid()) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  email        String
  displayName  String           @map("display_name")
  role         TenantUserRole
  /// Hash Argon2id (ou futuro apenas SSO Cognito sem password).
  passwordHash String?          @map("password_hash")
  active       Boolean          @default(true)
  cognitoSub   String?          @unique @map("cognito_sub")
  mfaEnabled   Boolean          @default(false) @map("mfa_enabled")
  /// Segredo TOTP base32 (em produção encriptar com KMS).
  mfaSecret    String?          @map("mfa_secret")
  emailVerifiedAt DateTime?     @map("email_verified_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  formadorProfile FormadorProfile?
  formandoProfile FormandoProfile?
  impersonationSessionsAsTarget ImpersonationSession[] @relation("ImpersonatedUserSessions")
  arquivosExportacao ArquivoExportacao[]
  rgpdConsent     RgpdConsent?
  faturasEmitidas FaturaComercial[] @relation("FaturaEmitidaPor")
  pedidosAnulacaoSolicitados FaturaPedidoAnulacao[] @relation("PedidoAnulacaoSolicitante")
  pedidosAnulacaoResolvidos  FaturaPedidoAnulacao[] @relation("PedidoAnulacaoResolvido")
  notificacoesPortal         NotificacaoPortal[]
  pushSubscriptions          PushSubscription[]
  leadsAtribuidos            LeadComercial[] @relation("LeadAtribuido")
  propostasEnviadas          PropostaComercial[] @relation("PropostaEnviadaPor")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
  @@schema("public")
}

model TenantInvite {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  email        String
  displayName  String?        @map("display_name")
  role         TenantUserRole
  tokenHash    String         @unique @map("token_hash")
  expiresAt    DateTime       @map("expires_at")
  acceptedAt   DateTime?      @map("accepted_at")
  invitedById  String         @map("invited_by_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("tenant_invites")
  @@schema("public")
}

model EntidadeCliente {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  nif          String
  nome         String
  moradaFiscal String?   @map("morada_fiscal") @db.Text
  email        String?
  telefone     String?
  createdAt    DateTime  @default(now()) @map("created_at")
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  formandos  FormandoProfile[]
  propostas  PropostaComercial[]
  leads      LeadComercial[]
  faturas    FaturaComercial[]
  documentos DocumentoAnexo[]

  @@unique([tenantId, nif])
  @@index([tenantId])
  @@map("entidades_cliente")
  @@schema("public")
}

model FormandoProfile {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  userId              String?          @unique @map("user_id") @db.Uuid
  entidadeClienteId   String?          @map("entidade_cliente_id") @db.Uuid
  nome                String
  nif                 String
  email               String?
  /// Email a usar no Zoom/Teams para contar assiduidade (gestor). Se vazio, usa a conta do tenant.
  emailPresenca       String?          @map("email_presenca")
  telefone            String?
  metadata            Json? // CC encriptado app-level, etc. – nunca em claro
  createdAt           DateTime        @default(now()) @map("created_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  entidadeCliente EntidadeCliente? @relation(fields: [entidadeClienteId], references: [id], onDelete: SetNull)
  matriculas      Matricula[]
  documentos      DocumentoAnexo[]

  @@unique([tenantId, nif])
  @@index([tenantId])
  @@index([tenantId, emailPresenca])
  @@map("formandos")
  @@schema("public")
}

model FormadorProfile {
  id               String           @id @default(uuid()) @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
  userId           String           @unique @map("user_id") @db.Uuid
  nomeCompleto    String           @map("nome_completo")
  nif              String
  email            String
  ccNumero         String?          @map("cc_numero")
  ccpNumero        String?          @map("ccp_numero")
  ccValidade       DateTime?        @map("cc_validade") @db.Date
  ccpValidade      DateTime?        @map("ccp_validade") @db.Date
  createdAt       DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessoesFormacao SessaoFormacao[]
  modulosUnidade  ModuloUnidade[]

  @@unique([tenantId, nif])
  @@index([tenantId])
  @@map("formadores")
  @@schema("public")
}

model Curso {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  /// ID sequencial por tenant (catálogo / website externo).
  codigoPublico     Int?            @map("codigo_publico")
  codigoUfcd        String?         @map("codigo_ufcd")
  designacao        String
  cargaHoras        Int             @map("carga_horas")
  modalidade        String          // presencial | b-learning | e-learning
  objetivos         String?
  enquadramento     String?         @db.Text
  metodoEnsino      String?         @map("metodo_ensino") @db.Text
  coverStorageKey   String?         @map("cover_storage_key")
  publicado         Boolean         @default(false)
  createdAt         DateTime        @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  acoesFormacao    AcaoFormacao[]
  modulosConteudo ModuloConteudo[]
  modulosUnidade  ModuloUnidade[]
  propostasComerciais PropostaComercial[]

  @@unique([tenantId, codigoPublico])
  @@index([tenantId])
  @@map("cursos")
  @@schema("public")
}

model AcaoFormacao {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  cursoId         String           @map("curso_id") @db.Uuid
  codigoInterno   String           @map("codigo_interno")
  titulo          String
  dataInicio      DateTime          @map("data_inicio") @db.Date
  dataFim         DateTime          @map("data_fim") @db.Date
  prazoConclusaoLms DateTime?       @map("prazo_conclusao_lms") @db.Date
  estado          AcaoEstado        @default(PLANEADA)
  inscricoesEstado InscricoesEstado @default(FECHADAS) @map("inscricoes_estado")
  publicado       Boolean          @default(false)
  /// Configuração original de agenda (repetição, horários) para sync com website.
  agendaTemplate  Json?            @map("agenda_template")
  createdAt       DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  curso Curso @relation(fields: [cursoId], references: [id], onDelete: Restrict)

  turmas    Turma[]
  cronogramas Cronograma[]
  arquivosExportacao ArquivoExportacao[]
  sigoSubmissoes SigoSubmissao[]
  documentosAnexo DocumentoAnexo[]

  @@unique([tenantId, codigoInterno])
  @@index([tenantId])
  @@map("acoes_formacao")
  @@schema("public")
}

model Turma {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  acaoFormacaoId  String         @map("acao_formacao_id") @db.Uuid
  codigo          String
  nome            String

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  acaoFormacao AcaoFormacao   @relation(fields: [acaoFormacaoId], references: [id], onDelete: Cascade)
  matriculas     Matricula[]
  folhasPresenca FolhaPresenca[]

  @@unique([tenantId, acaoFormacaoId, codigo])
  @@index([tenantId])
  @@map("turmas")
  @@schema("public")
}

model Matricula {
  id               String           @id @default(uuid()) @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
  turmaId          String           @map("turma_id") @db.Uuid
  formandoId       String           @map("formando_id") @db.Uuid
  estado           MatriculaEstado  @default(ATIVA)
  dataInscricao    DateTime         @default(now()) @map("data_inscricao")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  turma    Turma           @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  formando FormandoProfile @relation(fields: [formandoId], references: [id], onDelete: Cascade)

  presencas Presenca[]
  acessosLms AcessoLms[]
  progressosModulo ProgressoModulo[]
  certificadoVerificacao CertificadoVerificacao?
  quizTentativas QuizTentativa[]
  avaliacoes AvaliacaoFormando[]

  @@unique([turmaId, formandoId])
  @@index([tenantId])
  @@map("matriculas")
  @@schema("public")
}

model Cronograma {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  acaoFormacaoId  String           @map("acao_formacao_id") @db.Uuid
  versao          Int              @default(1)
  aprovadoPor     String?          @map("aprovado_por") @db.Uuid
  aprovadoEm      DateTime?        @map("aprovado_em")
  createdAt       DateTime         @default(now()) @map("created_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  acaoFormacao AcaoFormacao     @relation(fields: [acaoFormacaoId], references: [id], onDelete: Cascade)
  sessoes      SessaoFormacao[]

  @@unique([tenantId, acaoFormacaoId, versao])
  @@index([tenantId])
  @@map("cronogramas")
  @@schema("public")
}

model SessaoFormacao {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  cronogramaId    String           @map("cronograma_id") @db.Uuid
  numeroSessao    Int              @map("numero_sessao")
  data            DateTime         @db.Date
  horaInicio      String           @map("hora_inicio") // HH:mm
  horaFim         String           @map("hora_fim")
  local           String?
  modalidade      String
  estado          SessaoEstado     @default(AGENDADA)
  lmsAtivo        Boolean          @default(false) @map("lms_ativo")
  zoomMeetingId   String?          @map("zoom_meeting_id")
  teamsMeetingId  String?          @map("teams_meeting_id")
  salaJoinUrl     String?          @map("sala_join_url")
  minutosPresencaMin Int           @default(60) @map("minutos_presenca_min")
  formadorId      String?          @map("formador_id") @db.Uuid
  moduloUnidadeId String?          @map("modulo_unidade_id") @db.Uuid
  iniciadaEm      DateTime?        @map("iniciada_em")
  terminadaEm     DateTime?        @map("terminada_em")
  formadorPresente Boolean?        @map("formador_presente")
  createdAt       DateTime         @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cronograma Cronograma @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  formador   FormadorProfile? @relation(fields: [formadorId], references: [id], onDelete: SetNull)
  moduloUnidade ModuloUnidade? @relation(fields: [moduloUnidadeId], references: [id], onDelete: SetNull)

  sumarios        Sumario[]
  folhasPresenca  FolhaPresenca[]
  acessosLms      AcessoLms[]

  @@unique([cronogramaId, numeroSessao])
  @@index([tenantId])
  @@map("sessoes_formacao")
  @@schema("public")
}

