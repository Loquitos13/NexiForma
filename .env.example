# PostgreSQL (local: docker-compose)
DATABASE_URL="postgresql://nexiforma:nexiforma_dev@localhost:5432/nexiforma?schema=public"

# API (NestJS REST) — em dev evita 3000 (Next.js); alinha API_URL / NEXT_PUBLIC_API_URL com esta porta
API_PORT=3001
# Web Next.js (BFF + UI) - login em http://localhost:3000 ; não confundir com API_PORT
WEB_PORT=3000
# Swagger UI (servidor docs dedicado - futuro https://api.nexiforma.pt/docs)
API_DOCS_PORT=4001
# API_DOCS_PUBLIC_URL=http://localhost:4001
NODE_ENV=development

# App URL pública (convites, Stripe redirect)
# URL pública por defeito (fallback se o pedido não trouxer origem válida)
APP_PUBLIC_URL=http://localhost:3000

# JWT - produção: segredo forte (32+ caracteres), KMS/Vault recomendados
JWT_SECRET="dev-change-me-at-least-32-characters-long____"
JWT_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
JWT_REFRESH_REMEMBER_EXPIRES="30d"
# JWT_REFRESH_PEPPER=""  # obrigatório em produção (32+ chars)
# PASSWORD_RESET_PEPPER=""
# PASSWORD_RESET_ENCRYPTION_KEY=""
# SUBSCRIPTION_KEY_PEPPER=""
# SUPPORT_TICKET_ENCRYPTION_KEY=""  # fallback: PASSWORD_RESET_ENCRYPTION_KEY
# TENANT_ACCESS_KEY_PEPPER=""
# TENANT_ACCESS_KEY_TTL_HOURS=10   # validade da chave nf_access_ (superadmin → tenant)
# PLATFORM_SUPPORT_EMAIL=suporte@nexiforma.pt

# Row Level Security PostgreSQL (após enable_rls.sql; produção: role app_tenant na DATABASE_URL)
RLS_ENABLED=true

# Cookie HttpOnly do refresh
# COOKIE_SECURE=true          # obrigatório em produção (MITM)
# COOKIE_SAMESITE=strict      # default strict em produção
# AUTH_COOKIE_PATH=/v1/auth
# TRUST_PROXY=true            # obrigatório em produção atrás de ALB/nginx
# FORCE_HTTPS=true            # web: redirect HTTP→HTTPS (default activo em NODE_ENV=production)

# --- Anti-DDoS (rate limit por IP; produção: manter DDOS_ENABLED=true + WAF/ALB) ---
DDOS_ENABLED=true
# DDOS_API_LIMIT_PER_MIN=200
# DDOS_API_AUTH_LIMIT_PER_MIN=40
# DDOS_WEB_API_LIMIT_PER_MIN=120
# DDOS_WEB_AUTH_LIMIT_PER_MIN=25
# DDOS_WEB_PAGE_LIMIT_PER_MIN=300
# DDOS_WEB_BURST_PER_10S=40

# Bloqueio após credenciais inválidas repetidas (por conta: tenant+email ou email plataforma)
# LOGIN_FAIL_MAX_ATTEMPTS=5
# LOGIN_FAIL_WINDOW_MS=900000
# LOGIN_FAIL_LOCKOUT_MS=900000

# Criar salas Zoom/Teams automaticamente na véspera (requer OAuth + CRON_NOTIFICACOES_ENABLED)
# CRON_REUNIOES_AUTO_ENABLED=true

# CORS - origens separadas por vírgula (produção: só https://)
# CORS_ORIGIN=http://localhost:3000,https://app.nexiforma.pt

# Email – Brevo API (recomendado; usa BREVO_API_KEY da tab API Settings)
# MAIL_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-...
#
# Alternativa SMTP Brevo (SMTP_PASS ≠ API key):
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
#
# AWS SES (alternativa produção):
# MAIL_PROVIDER=ses
# AWS_REGION=eu-west-1
#
# Cron: lembretes 18h, digest 8h, inspeção seg 9h (só email)
# CRON_NOTIFICACOES_ENABLED=true
# Leads comerciais da welcome page (fallback: MAIL_REPLY_TO / MAIL_FROM)
# PLATFORM_SALES_EMAIL=vendas@nexiforma.pt
# Alertas email superadmin em erros HTTP 4xx/5xx (default: activo)
# PLATFORM_ERROR_ALERTS_ENABLED=true
# Health checks automáticos do centro de operações (a cada 10 min)
# PLATFORM_OPS_CRON_ENABLED=true
# PASSWORD_RESET_TTL_MINUTES=60
# PASSWORD_RESET_ENCRYPTION_KEY=""  # AES-256 para parâmetro u encriptado nos links (fallback: JWT_SECRET)
#
# SMS / push / Telegram – NÃO necessários (omitir SMS_PROVIDER e VAPID_*)

# Assinatura CMD (Chave Móvel Digital) - sumários
# CMD_SIGNATURE_MODE=disabled
# CMD_SIGNATURE_MODE=oauth
# CMD_OAUTH_URL=https://autenticacao.gov.pt/oauth2/...

# Stripe billing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# AWS Cognito (opcional - login enterprise + MFA)
# AWS_REGION=eu-west-1
# COGNITO_ISSUER=https://cognito-idp.eu-west-1.amazonaws.com/eu-west-1_XXXXX
# COGNITO_CLIENT_ID=

# Zoom webhook (assiduidade automática)
# ZOOM_WEBHOOK_TOKEN=dev-zoom-secret

# Microsoft Teams webhook (assiduidade)
# TEAMS_WEBHOOK_TOKEN=dev-teams-secret

# MFA obrigatório para gestores (ADMIN/COORDENADOR/FINANCEIRO)
# MFA_REQUIRED_MANAGERS=false

# Storage (dev: local; produção: S3)
# STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=./storage
# AWS_REGION=eu-west-1
# S3_BUCKET=nexiforma-storage
# Chaves S3: formandos/{tenantId}/{formandoId}/… | documentos/… | lms/… | exports/…
# IAM ECS: s3:PutObject, s3:GetObject, s3:DeleteObject no bucket
# STORAGE_EXPORT_TTL_DAYS=90
# STORAGE_PUBLIC_BASE_URL=  # opcional CDN; senão usar endpoints API autenticados

# Fila assiduidade - dev: redis; prod: sqs
# REDIS_URL=redis://localhost:6379
# QUEUE_BACKEND=redis
# QUEUE_ENABLED=true
# SQS_ASSIDUIDADE_URL=https://sqs.eu-west-1.amazonaws.com/123456789/nexiforma-assiduidade

# Observabilidade (logs JSON → CloudWatch Logs)
# OBSERVABILITY_ENABLED=true
# AWS_XRAY_ENABLED=true

# SIGO – SOAP (produção DGEEC) ou HTTP (dev local). Credenciais por entidade em /portal/sigo
SIGO_API_MODE=soap
# SOAP (DGEEC): TLS 1.2+, WS-Security, IP whitelisted
# SIGO_SOAP_WSDL_URL=https://sigo.example.gov.pt/ws/ServiceMatriculas?wsdl
# SIGO_SOAP_ENDPOINT=https://sigo.example.gov.pt/ws/ServiceMatriculas
# SIGO_SOAP_NAMESPACE=http://sigo.dgeec.mec.pt/ws
# SIGO_SOAP_ACTION_SUBMIT=SubmeterAcao
# SIGO_SOAP_ACTION_CONSULTAR=ConsultarEstado
# SIGO_SOAP_FORCE_RAW_XML=false   # true = ignora módulo soap, usa POST XML manual
# SIGO_PUBLIC_IP=203.0.113.10
# HTTP (apenas dev com scripts/sigo-mock-api.mjs):
# SIGO_API_MODE=http
# SIGO_API_BASE_URL=http://localhost:3099
# Chave de encriptação (obrigatória para guardar API keys por tenant)
# AT_CREDENTIALS_ENCRYPTION_KEY=dev-change-me-32-chars-minimum____
# Por entidade: configurar API key em /portal/sigo (não usar SIGO_API_KEY global)
# Teste local sem DGEEC: node scripts/sigo-mock-api.mjs  (servidor HTTP real na porta 3099)
# SIGO_SUBMIT_PAYLOAD_FORMAT=dgeec  # dgeec | nexiforma | dual
# SIGO_API_HEALTH_PATH=/health
# SIGO_API_TIMEOUT_MS=30000
# SIGO_API_MAX_RETRIES=2
# SIGO_API_SUBMIT_PATH=/acoes
# SIGO_API_STATUS_PATH=/acoes/{referenceId}
# SIGO_API_CERTIFICADOS_PATH=/acoes/{referenceId}/certificados
# SIGO_API_CERTIFICADO_DOWNLOAD_PATH=/certificados/{certificadoId}/download
# CRON_SIGO_ENABLED=true          # reconciliação + sync certificados (fallback: CRON_NOTIFICACOES_ENABLED)

# Faturação AT – sandbox REAL (porta 700) ou mock local (offline)
# AT_FATURAS_MODE=disabled
# AT_FATURAS_MODE=sandbox          # webservice AT testes :700 (default)
# AT_FATURAS_SANDBOX_MOCK=1        # opcional: simulação local sem HTTP
# AT_FATURAS_MODE=production
# AT_FATURAS_SANDBOX_FAIL=0
# AT_FATURAS_SANDBOX_REQUIRE_CREDS=0
# AT_FATURAS_ENDPOINT=https://servicos.portaldasfinancas.gov.pt:700/fews/faturas
# AT_FATURAS_TIMEOUT_MS=30000
# AT_FATURAS_WSDL_URL=https://servicos.portaldasfinancas.gov.pt:700/fews/faturas?wsdl
# AT_EFATURA_MD_VERSION=0.0.1
# AT_AUDIT_FILE_VERSION=1.04_01
# AT_SOFTWARE_CERT_NUMBER=9999
# AT_TEST_NIF=599999993
# AT_TEST_SUBUSER=37
# AT_TEST_PASSWORD=testes1234
# Assinatura RSA-SHA1 encadeada (SAF-T / certificação AT)
# AT_SAFT_PRIVATE_KEY_PATH=./chaveprivada.txt
# AT_SAFT_HASH_CONTROL=1
# Comunicação de séries (WSE – Portaria 195/2020, sandbox :722)
# AT_SERIES_MODE=disabled
# AT_SERIES_MODE=sandbox
# AT_SERIES_SANDBOX_MOCK=1
# AT_SERIES_MODE=production
# AT_SERIES_ENDPOINT=https://servicos.portaldasfinancas.gov.pt:722/SeriesWSService
# AT_SERIES_TIMEOUT_MS=30000
# AT_SERIES_AUTO_REGISTER=1
# AT_SERIES_SANDBOX_FAIL=0
# Certificados AT testes – ver certs/README.md
# AT_FATURAS_PUBLIC_KEY_PATH=./certs/at-public-key.pem
# AT_FATURAS_CLIENT_CERT_PFX_PATH=./certs/TesteWebservices.pfx
# AT_FATURAS_CLIENT_CERT_PEM_PATH=./certs/TesteWebservices.pem
# AT_FATURAS_CLIENT_CERT_PASSPHRASE=TESTEwebservice
# AT_CREDENTIALS_ENCRYPTION_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:suporte@nexiforma.pt

# --- App Microsoft NexiForma (multi-tenant SaaS - uma vez na plataforma) ---
# Regista app Azure "Accounts in any organizational directory" + permissões Application:
# OnlineMeetings.ReadWrite.All, User.Read.All
# NEXIFORMA_TEAMS_CLIENT_ID=
# NEXIFORMA_TEAMS_CLIENT_SECRET=
# NEXIFORMA_TEAMS_CONSENT_REDIRECT=http://localhost:3000/plataforma/microsoft/consent

# Por tenant cliente (Control Plane /plataforma/tenantes/:id): tenantId M365 + organizerId
# Zoom por tenant: credenciais Server-to-Server da conta Zoom do cliente
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_USER_ID=

# Moodle Web Services
# MOODLE_BASE_URL=https://moodle.example.edu
# MOODLE_WS_TOKEN=

# Subscription keys (Control Plane)
# SUBSCRIPTION_KEY_PEPPER=""
# SEED_SUPERADMIN_PASSWORD=""
# SEED_MANAGER_PASSWORD=""
# SEED_FORMADOR_PASSWORD=""
# SEED_FORMANDO_PASSWORD=""

# SCORM upload (máx. 50 MB por pacote)
# SCORM_MAX_UPLOAD_MB=50

# NexiGuia - LLM próprio (Ollama, self-hosted)
# Dev: docker compose up -d ollama  →  npm run ollama:pull
# NEXIGUIA_LLM_ENABLED=true
# NEXIGUIA_LLM_URL=http://127.0.0.1:11435
# (11435 = Docker; evita conflito com Ollama nativo no Windows em 11434)
# API em Docker (prod): NEXIGUIA_LLM_URL=http://ollama:11434
# NEXIGUIA_LLM_MODEL=qwen2.5:3b-instruct
# NEXIGUIA_LLM_TIMEOUT_MS=120000
# Timeout do proxy BFF (Next → API). Insights herda max(NEXIGUIA_LLM_TIMEOUT_MS, 120s) + 30s.
# NEXI_BACKEND_PROXY_TIMEOUT_MS=60000
# NEXI_BACKEND_PROXY_INSIGHTS_TIMEOUT_MS=180000
# (CRM notas/sugestões IA reutilizam estas variáveis - Ollama local, 0€)

# URL pública da app (launch URLs SCORM absolutos em produção)
# APP_PUBLIC_URL=https://app.nexiforma.pt
# URL pública da API (OAuth SSO callback, integrações)
# API_PUBLIC_URL=https://api.nexiforma.pt
# Swagger UI (servidor docs - mesma máquina, porta API_DOCS_PORT)
# NEXT_PUBLIC_API_DOCS_URL=http://localhost:4001
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
API_URL=http://127.0.0.1:3001
# Origens extra para dev (Docker/WSL): NEXT_ALLOWED_DEV_ORIGINS=172.18.48.1,192.168.1.10
# BFF_AUTH_COOKIE_PATH=/   # default: / (cookie visível ao middleware /portal)
# NEST_AUTH_COOKIE_PATH=/v1/auth

